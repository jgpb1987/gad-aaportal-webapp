<h3 class="text-center fw-bold">Form101</h3>

<div class="container mt-3">
    <div class="row">
        <div class="col-6 fw-bold">Razón Social:</div>
        <div class="col-6">@razSocial</div>

        <div class="col-6 fw-bold">RUC:</div>
        <div class="col-6">@ruc</div>

        <div class="col-6 fw-bold">Año</div>
        <div class="col-6">
            <select class="form-select"
                    @bind="anioSeleccionado"
                    @bind:after="OnAnioChanged">
                <option value="">-- Seleccione --</option>
                @foreach (var a in anios)
                {
                    <option value="@a">@a</option>
                }
            </select>
        </div>
    </div>
</div>

@if (ingresosEgresos != null)
{
    <div class="container mt-4">

        <div class="row justify-content-center">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td colspan="3" class="fw-bold text-center">
                            DETALLE DE ACTIVOS
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Activos Corrientes:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   @bind-value:get="ingresosEgresos.TotalActivoCorriente470"
                                   @bind-value:set="(v) => { ingresosEgresos.TotalActivoCorriente470 = Convert.ToDecimal(v); RecalcularActivos(); }"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(a)</td>
                    </tr>
                    <tr>
                        <td>
                            Activos no Corrientes:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   @bind-value:get="ingresosEgresos.TotActivoNoCorriente1077"
                                   @bind-value:set="(v) => { ingresosEgresos.TotActivoNoCorriente1077 = Convert.ToDecimal(v); RecalcularActivos(); }"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(b)</td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Total Activos:
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalActivo1080
                        </td>
                        <td>(c)</td>
                    </tr>
                </table>
            </div>

            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td colspan="3" class="fw-bold text-center">
                            DETALLE DE PASIVOS
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Pasivo Corriente:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number" step="0.01"
                                   @bind-value:get="ingresosEgresos.TotPasivosCorrientes1340"
                                   @bind-value:set="(v) => { ingresosEgresos.TotPasivosCorrientes1340 = Convert.ToDecimal(v); RecalcularPasivos(); }"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(d)</td>
                    </tr>
                    <tr>
                        <td>
                            Pasivo no Corriente:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number" step="0.01"
                                   @bind-value:get="ingresosEgresos.TotalPasivosLargoPlazo1590"
                                   @bind-value:set="(v) => { ingresosEgresos.TotalPasivosLargoPlazo1590 = Convert.ToDecimal(v); RecalcularPasivos(); }"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(e)</td>
                    </tr>
                    <tr>
                        <td>Pasivo Contingente:</td>
                        <td>
                            <input class="form-control text-end" value="" />
                        </td>
                        <td>(f)</td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Total Pasivo:
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalPasivos1620
                        </td>
                        <td>(g)</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Patrimonio centrado -->
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr class="fw-bold">
                        <td>
                            Patrimonio:
                        </td>
                        <td class="text-end">
                            @(ingresosEgresos.TotalActivo1080 - ingresosEgresos.TotalPasivos1620)
                        </td>
                        <td>(h)</td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Base 1.5*1000 Activo Total
                        </td>
                        <td class="text-end">
                            @baseForm
                        </td>
                        <td>(i)</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Ingresos centrado -->
        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td>
                            Ingresos:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   @bind-value="ingresosEgresos.TotalIngresos1930"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(j)</td>
                    </tr>
                    <tr>
                        <td>
                            Costos / Gastos:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   @bind-value="ingresosEgresos.TotasCostosGastos3380"
                                   @bind-value:event="oninput" />
                        </td>
                        <td>(k)</td>
                    </tr>
                    <tr class="fw-bold">
                        <td class="text-end">
                            @(ingresosEgresos.UtilidadEjercicio3420 >= 0 ? "Utilidad" : "Pérdida")
                        </td>
                        <td class="text-end">
                            @(ingresosEgresos.TotalIngresos1930 - ingresosEgresos.TotasCostosGastos3380)
                        </td>
                        <td>(l)</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div style="width:25%">
        <CheckDropdownGrouped TItem="Canton"
                              TGroup="string"
                              Items="@cantones.Cantones"
                              Selected="@selectedCantones"
                              SelectedChanged="@((v) => selectedCantones = v)"
                              GroupBySelector="c => c.Provincia"
                              GroupSelector="prov => prov"
                              ValueSelector="c => c.Id.ToString()"
                              TextSelector="c => c.NombreCanton" />
    </div>
    <p>PRUEBA</p>
}
