<h3 class="text-center fw-bold">Form101</h3>

<div class="container mt-3">
    <div class="row">
        <div class="col-6 fw-bold">Razón Social:</div>
        <div class="col-6">@razSocial</div>

        <div class="col-6 fw-bold">RUC:</div>
        <div class="col-6">@ruc</div>

        <div class="col-6 fw-bold">Año</div>
        <div class="col-6">
            <select class="form-select"
                    @bind="anioSeleccionado"
                    @bind:after="OnAnioChanged">
                <option value="">-- Seleccione --</option>
                @foreach (var a in anios)
                {
                    <option value="@a">@a</option>
                }
            </select>
        </div>
    </div>
</div>

@if (ingresosEgresos != null)
{
    <div class="container mt-4">

        <div class="row justify-content-center">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td colspan="3" class="fw-bold text-center">
                            DETALLE DE ACTIVOS
                        </td>
                    </tr>
                    <tr>
                        <td class="fw-bold text-center">
                        </td>
                        <td class="fw-bold text-center">
                            Declarado
                        </td>
                        <td class="fw-bold text-center">
                            Sugerido
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Activos Corrientes:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.TotalActivoCorriente470"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalActivoCorriente470
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Activos no Corrientes:
                        </td>
                        <td class="text-end">
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.TotActivoNoCorriente1077"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotActivoNoCorriente1077
                        </td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Total Activos:
                        </td>
                        <td class="text-end">
                            <input class="form-control text-end" readonly value="@declaracion.TotalActivo1080" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalActivo1080
                        </td>
                    </tr>
                </table>
            </div>

            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr class="fw-bold text-center">
                        <td colspan="3">
                            DETALLE DE PASIVOS
                        </td>
                    </tr>
                    <tr class="fw-bold text-center">
                        <td></td>
                        <td>
                            Declarado
                        </td>
                        <td>
                            Sugerido
                        </td>
                        <td></td>
                    </tr>
                    <tr>
                        <td>
                            Pasivo Corriente:
                        </td>
                        <td class="text-end">
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.TotPasivosCorrientes1340"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotPasivosCorrientes1340
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Pasivo no Corriente:
                        </td>
                        <td class="text-end">
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.TotalPasivosLargoPlazo1590"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalPasivosLargoPlazo1590
                        </td>
                    </tr>
                    <tr>
                        <td>Pasivo Contingente:</td>
                        <td class="text-end">
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.TotalPasivosContingente"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            0
                        </td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Total Pasivo:
                        </td>
                        <td class="text-end">
                            <input class="form-control text-end" readonly value="@declaracion.TotalPasivos1620" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalPasivos1620
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td></td>
                        <td class="fw-bold">
                            Declarado
                        </td>
                        <td class="fw-bold">
                            Sugerido
                        </td>
                        <td></td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            Patrimonio:
                        </td>
                        @{
                            var diferencia = declaracion.TotalActivo1080 - declaracion.TotPasivosCorrientes1340;
                        }
                        <td class="text-end @(diferencia < 0 ? "text-danger" : "")">
                            @(Math.Abs(diferencia).ToString("N2"))
                        </td>
                        <td class="text-end">
                            @(ingresosEgresos.TotalActivo1080 - ingresosEgresos.TotalPasivos1620)
                        </td>
                    </tr>
                    <tr class="fw-bold">
                        <td>
                            1.5 x Mil:
                        </td>
                        <td class="text-end">
                            @declaracion.ValorUnoPuntoCinco
                        </td>
                        <td class="text-end">
                            @baseForm
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6">
                <table class="table table-bordered">
                    <tr>
                        <td></td>
                        <td class="text-center; fw-bold">
                            Declarado
                        </td>
                        <td class="text-center; fw-bold">
                            Sugerido
                        </td>
                        <td></td>
                    </tr>
                    <tr>
                        <td>
                            Ingresos:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.Ingresos"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotalIngresos1930
                        </td>
                    </tr>
                    <tr>
                        <td>
                            Costos / Gastos:
                        </td>
                        <td>
                            <input class="form-control form-control-editable text-end"
                                   type="number"
                                   step="0.01"
                                   min="0.00"
                                   @bind-value="declaracion.Egresos"
                                   @bind-value:event="oninput" />
                        </td>
                        <td class="text-end">
                            @ingresosEgresos.TotasCostosGastos3380
                        </td>
                    </tr>
                    <tr class="fw-bold">
                        <td class="text-end">
                            @LabelResultado
                        </td>
                        <td class="text-end @(declaracion.UtilidadPerdida < 0 ? "text-danger" : "")">
                            @(Math.Abs(declaracion.UtilidadPerdida).ToString("N2"))
                        </td>
                        <td class="text-end">
                            @Math.Abs(ingresosEgresos.TotalIngresos1930.Value - ingresosEgresos.TotasCostosGastos3380.Value)
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row justify-content-center mt-4">
            <div class="col-12 col-md-6">
                @if (cantones == null || !cantones.Cantones.Any())
                {
                    <p>Cargando cantones...</p>
                }
                else
                {
                    <div style="max-height:350px; overflow-y:auto; border:1px solid #ccc; padding:5px;">
                        @foreach (var prov in cantones.Cantones.GroupBy(c => c.Provincia))
                        {
                            var collapsed = collapsedStates.Contains(prov.Key);

                            <div class="mb-2">
                                <button class="btn btn-sm btn-secondary"
                                        @onclick="() => ToggleCollapse(prov.Key)">
                                    @(collapsed ? "+" : "-")
                                </button>
                                <strong>@prov.Key</strong>
                            </div>

                            @if (!collapsed)
                            {
                                <table class="table table-sm">
                                    <tr class="fw-bold text-center">
                                        <td>
                                            Cantón
                                        </td>
                                        <td></td>
                                        <td>
                                            Porcentaje
                                        </td>
                                        <td>
                                            Pago Aquí
                                        </td>
                                    </tr>
                                    @foreach (var canton in prov)
                                    {
                                        <tr>
                                            <td>@canton.NombreCanton</td>
                                            <td class="text-start">
                                                <input type="checkbox"
                                                       checked="@canton.Seleccionado"
                                                       @onchange="(e) => ToggleCanton(canton, e.Value)"
                                                       disabled="@(canton.NombreCanton == "Antonio Ante")" />
                                            </td>
                                            <td style="width:100px">
                                                <input type="number"
                                                       class="form-control form-control-sm"
                                                       step="0.01"
                                                       min="@(canton.NombreCanton == "Antonio Ante" ? 0.01 : 0)"
                                                       max="100"
                                                       @bind-value="canton.Porcentaje"
                                                       @bind-value:event="oninput"
                                                       disabled="@(!canton.Seleccionado)"
                                                       @bind-value:after="() => ValidarSuma(canton)" />
                                            </td>
                                            <td class="text-center">
                                                <input type="checkbox"
                                                       checked="@canton.PagoAA"
                                                       disabled="@(canton.NombreCanton == "Antonio Ante")" />
                                            </td>
                                        </tr>
                                    }
                                </table>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    </div>
}
