@page "/form101"
<ToastsServices @ref="Toast" Time="5000" />

<BsModal @ref="myModal"
         Title="@modalTitle"
         Size="@modalSize">
    <ChildContent>
        @modalMessage
    </ChildContent>
</BsModal>

<div class="container mt-3">
    <div class="row align-items-stretch">
        <div class="col-12 col-md-8 d-flex flex-column justify-content-start">
            <div class="row g-2">
                <div class="col-12 col-md-4 fw-bold">RUC:</div>
                <div class="col-12 col-md-8">@ruc</div>

                <div class="col-12 col-md-4 fw-bold">Razón Social:</div>
                <div class="col-12 col-md-8">@razSocial</div>

                <div class="col-12 col-md-4 fw-bold">Año:</div>
                <div class="col-12 col-md-8">
                    <select class="form-select"
                            @bind="anioSeleccionado"
                            @bind:after="OnAnioChanged">
                        <option value="">-- Seleccione --</option>
                        @foreach (var a in anios)
                        {
                            <option value="@a">@a</option>
                        }
                    </select>
                </div>
            </div>
        </div>
        <fieldset disabled="@(btnMains || bloqueoFormulario)" class="col-12 col-md-4 d-flex flex-column justify-content-between">
            <div>
                <div class="text-center mt-3">
                    <button class="btn btn-primary w-50" @onclick="GeneraOrdenPago">Aceptar y Guardar</button>
                </div>
            </div>
        </fieldset>
    </div>
</div>

@if (ingresosEgresos != null)
{
    <fieldset disabled="@bloqueoFormulario">
        <div class="container mt-4">
            <div class="row justify-content-center mb-4">
                <div class="col-12 col-md-6 mb-3 mb-md-0">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tr>
                                <td colspan="3" class="fw-bold text-center">DETALLE DE ACTIVOS</td>
                            </tr>
                            <tr>
                                <td>Activos Corrientes:</td>
                                <td class="text-end">@ingresosEgresos.ActivoCorriente</td>
                            </tr>
                            <tr>
                                <td>Activos no Corrientes:</td>
                                <td class="text-end">@ingresosEgresos.ActivoNoCorriente</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Total Activos:</td>
                                <td class="text-end">@ingresosEgresos.TotalActivos</td>
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tr class="fw-bold text-center">
                                <td colspan="3">DETALLE DE PASIVOS</td>
                            </tr>
                            <tr class="fw-bold text-center">
                                <td></td>
                                <td>Declarado</td>
                                <td>Sugerido</td>
                            </tr>
                            <tr>
                                <td>Pasivo Corriente:</td>
                                <td class="text-end">
                                    <input class="form-control form-control-editable text-end"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           max="@ingresosEgresos.PasivoCorriente"
                                           @bind="declaracion.PasivoCorriente"
                                           @bind:event="oninput"
                                           @bind:after="ValidarPasivo" />
                                </td>
                                <td class="text-end">@ingresosEgresos.PasivoCorriente</td>
                            </tr>
                            <tr>
                                <td>Pasivo no Corriente:</td>
                                <td class="text-end">
                                    <input class="form-control form-control-editable text-end"
                                           type="number" step="0.01" min="0.00"
                                           @bind-value="declaracion.PasivoLargoPlazo"
                                           @bind-value:event="oninput" />
                                </td>
                                <td class="text-end">@ingresosEgresos.PasivoNoCorriente</td>
                            </tr>
                            <tr>
                                <td>Pasivo Contingente:</td>
                                <td class="text-end">
                                    <input class="form-control form-control-editable text-end"
                                           type="number" step="0.01" min="0.00"
                                           @bind-value="declaracion.PasivoContingente"
                                           @bind-value:event="oninput" />
                                </td>
                                <td class="text-end">0</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Total Pasivo:</td>
                                <td class="text-end">
                                    <input class="form-control text-end" readonly value="@declaracion.TotalPasivos" />
                                </td>
                                <td class="text-end">@ingresosEgresos.TotalPasivos</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="row justify-content-center mt-4">
                <div class="col-12 col-md-6 mb-3 mb-md-0">
                    <div class="table-responsive">
                        <table class="table table-bordered">
                            <tr>
                                <td colspan="2" class="fw-bold text-center">DETALLE DE INGRESOS/COSTOS</td>
                            </tr>
                            <tr>
                                <td>Ingresos:</td>
                                <td class="text-end">@ingresosEgresos.Ingresos</td>
                            </tr>
                            <tr>
                                <td>Costos / Gastos:</td>
                                <td class="text-end">@ingresosEgresos.CostosGastos</td>
                            </tr>
                            <tr class="fw-bold">
                                <td class="text-start">@LabelResultado</td>
                                <td class="text-end @(declaracion.UtilidadEjercicio3420 < 0 ? "text-danger" : "")">
                                    @(Math.Abs(declaracion.UtilidadEjercicio3420).ToString("N2"))
                                </td>
                            </tr>
                        </table>
                    </div>
                    <div class="table-responsive mb-3">
                        <table class="table table-bordered">
                            <tr>
                                <td></td>
                                <td class="fw-bold">Declarado</td>
                                <td class="fw-bold">Sugerido</td>
                            </tr>
                            <tr class="fw-bold">
                                <td>Patrimonio:</td>
                                @{
                                    var diferencia = declaracion.TotalActivos - declaracion.TotalPasivos;
                                }
                                <td class="text-end @(diferencia < 0 ? "text-danger" : "")">
                                    @(Math.Abs(diferencia).ToString("N2"))
                                </td>
                                <td class="text-end">
                                    @(ingresosEgresos.TotalActivos - ingresosEgresos.TotalPasivos)
                                </td>
                            </tr>
                            <tr class="fw-bold" style="background-color:darkgrey">
                                <td>1.5 x Mil:</td>
                                <td class="text-end">@declaracion.ValorUnoPorMil</td>
                                <td class="text-end">@baseForm</td>
                            </tr>
                            <tr class="fw-bold" style="background-color:darkgrey">
                                <td>
                                    Patente:
                                    @if (!LabelResultado.Equals("Utilidad"))
                                    {
                                        <input type="checkbox" title="Decuento" @onchange="AplicaDescuento" />
                                    }
                                </td>
                                <td class="text-end">
                                    @declaracion.ValorPatente
                                </td>
                                <td class="text-end">@ingresosEgresos.ValorPatente</td>
                            </tr>
                        </table>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <CantonesSelection Cantones="cantones.Cantones" Toast="Toast"
                                       OnPorcentajeCambiado="CalcularPatenteDeclarada" />
                </div>
            </div>
        </div>
    </fieldset>
}
